generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  INBOX
  EVALUATING
  PLANNED
  IN_PROGRESS
  WAITING_FOR_APPROVAL
  DONE
  BLOCKED
}

enum TaskType {
  SEO_AUDIT
  KEYWORD_CLUSTER
  META_REWRITE
  BLOG_BRIEF
  LINKEDIN_POST_SET
  X_POST_SET
  HOMEPAGE_COPY_SUGGESTION
  COMPETITOR_SCAN
}

enum TaskSource {
  SYSTEM
  USER
  AGENT
}

enum OwnerType {
  AGENT
  USER
  SYSTEM
}

enum ArtifactType {
  BLOG_BRIEF
}

enum ArtifactStatus {
  DRAFT
  WAITING_FOR_APPROVAL
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Workspace {
  id          String    @id
  name        String
  description String?
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Project {
  id              String            @id
  workspaceId     String
  websiteUrl      String
  name            String
  websiteSnapshot WebsiteSnapshot?
  companyProfile  CompanyProfile?
  tasks           Task[]
  artifacts       Artifact[]
  agentRuns       AgentRun[]
  approvals       Approval[]
  comments        Comment[]
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model WebsiteSnapshot {
  id               String   @id
  projectId        String   @unique
  websiteUrl       String
  homepageTitle    String
  crawledPagesJson String
  summary          String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CompanyProfile {
  id                    String   @id
  projectId             String   @unique
  companySummary        String
  guessedICP            String
  keyPagesJson          String
  opportunitiesJson     String
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Task {
  id             String      @id
  projectId      String
  title          String
  description    String
  type           TaskType
  source         TaskSource
  status         TaskStatus
  impact         Float
  effort         Float
  confidence     Float
  goalFit        Float
  priorityScore  Float
  rationale      String
  dependencies   String?
  ownerType      OwnerType
  movementLogJson String
  artifactId     String?     @unique
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact       Artifact?   @relation(fields: [artifactId], references: [id])
  comments       Comment[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Artifact {
  id            String         @id
  projectId     String
  type          ArtifactType
  title         String
  content       String
  status        ArtifactStatus
  task          Task?
  approvals     Approval[]
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model AgentRun {
  id            String   @id
  projectId     String
  taskId        String?
  runType       String
  status        String
  summary       String
  outputJson    String?
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Approval {
  id            String         @id
  projectId     String
  artifactId    String
  status        ApprovalStatus
  requestedBy   String
  decisionNote  String?
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact      Artifact       @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Comment {
  id            String   @id
  projectId     String
  taskId        String?
  body          String
  author        String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task          Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
